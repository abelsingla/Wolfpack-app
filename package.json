{
  "name": "wolfpack-campaign-log",
  "version": "0.1.0",
  "private": true,
  "description": "Portable Wolfpack boardgame campaign logger",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop:mac": "vite build && electron-builder --mac dir",
    "desktop:win": "vite build && electron-builder --win portable",
    "desktop:all": "vite build && electron-builder --mac dir --win portable"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.wolfpack.campaignlog",
    "productName": "Wolfpack Campaign Log",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.games"
    },
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
